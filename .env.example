# ============================================================
# Report Platform — Environment Variables
# Copy this file to .env and adjust values as needed.
# Never commit .env to version control.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reports

# ── Backend ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/reports
DEBUG=false

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Storage ──────────────────────────────────────────────────
# Path inside the container where generated report files are written.
# Mapped to the storage_data Docker volume in docker-compose.yml.
STORAGE_PATH=/storage

# ── Frontend ─────────────────────────────────────────────────
# Base URL for API calls from the browser.
# In development, Vite proxies /api → backend:8000.
VITE_API_BASE_URL=/api/v1
